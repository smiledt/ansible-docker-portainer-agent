# I do not want to accidentally upload a vault password
.vault_pass
*.vaultpass
.ansible

# Ignore inventory and config files as well.
*.inv
*.cfg

# Ignore additional autogenerated files, except for git ones
.*
*.retry
*.pyc
*.DS_Store
*.DS_Store?
*pytestdebug.log
roles/.DS_Store
*.vscode/
!.gitignore
!.github

# Ignore vars folder I will use for testing. See defaults folder for variable examples.
vars/